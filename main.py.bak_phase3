@app.get("/api/sync-history/{account_id}")
async def route_sync_history(account_id: str, db=Depends(get_db)):
    try:
        from database import TradeHistory, SessionHistory
        import json as _j
        raw_trades   = db.query(TradeHistory).filter(TradeHistory.account_id == account_id).order_by(TradeHistory.created_at.desc()).limit(500).all()
        raw_sessions = db.query(SessionHistory).filter(SessionHistory.account_id == account_id).order_by(SessionHistory.created_at.desc()).limit(90).all()
        trades = [
            {"id":t.id,"account_id":t.account_id,"session_id":t.session_id,
             "symbol":t.symbol,"trade_type":t.trade_type,"volume":t.volume,
             "open_price":t.open_price,"close_price":t.close_price,
             "pnl":t.pnl,"rr_ratio":t.rr_ratio,"risk_amount":t.risk_amount,
             "actual_rr":t.actual_rr,"opened_at":t.opened_at,"closed_at":t.closed_at}
            for t in raw_trades
        ]
        sessions = [
            {"session_id":s.session_id,"account_id":s.account_id,"date":s.date,
             "opening_balance":s.opening_balance,"closing_balance":s.closing_balance,
             "pnl":s.pnl,"max_dd":s.max_dd,"trade_count":s.trade_count,
             "win_count":s.win_count,"loss_count":s.loss_count,
             "summary":_j.loads(s.summary or "{}")}
            for s in raw_sessions
        ]
        return {"status":"ok","trades":trades,"sessions":sessions,
                "meta":{"account_id":account_id,"trade_count":len(trades),"session_count":len(sessions),
                        "synced_at":datetime.utcnow().isoformat()+"Z"}}
    except Exception as e:
        return {"status":"ok","trades":[],"sessions":[],
                "meta":{"account_id":account_id,"trade_count":0,"session_count":0,
                        "warning":str(e)[:100],"synced_at":datetime.utcnow().isoformat()+"Z"}}

@app.get("/api/ai-analysis/{account_id}")
async def route_ai_analysis(account_id: str):
    return api_get_ai_analysis(account_id)

# ══════════════════════════════════════════════════════════════════
# ADMIN
# ══════════════════════════════════════════════════════════════════
@app.post("/admin/licenses")
async def admin_create_license(
    request: Request,
    owner_name:   str = Query(""),
    owner_email:  str = Query(""),
    plan:         str = Query("standard"),
    max_machines: int = Query(1),
    expires_at:   str = Query(""),
    note:         str = Query(""),
    db=Depends(get_db)
):
    _check_admin(request)
    key = generate_license_key(plan.upper())
    exp = None
    if expires_at:
        try: exp = datetime.fromisoformat(expires_at)
        except: pass
    lic = License(
        license_key=key, tier=plan, status="ACTIVE",
        buyer_email=owner_email or "admin@zarmor.com",
        buyer_name=owner_name, bound_mt5_id=None,
        expires_at=exp, max_machines=max_machines, notes=note,
    )
    db.add(lic); db.commit()
    logger.info(f"[ADMIN] LICENSE CREATED | key={key} owner={owner_name} plan={plan}")
    return {"status":"created","key":key,"owner":owner_name,"plan":plan,
            "max_machines":max_machines,"expires_at":expires_at or "lifetime"}

@app.get("/admin/licenses")
async def admin_list_licenses(request: Request, db=Depends(get_db)):
    _check_admin(request)
    rows = db.query(License).order_by(License.id.desc()).all()
    return [{
        "id":r.id,"license_key":r.license_key,"tier":r.tier,"status":r.status,
        "bound_mt5_id":r.bound_mt5_id,"buyer_email":r.buyer_email,
        "buyer_name":r.buyer_name,"is_trial":r.is_trial,
        "expires_at":r.expires_at.isoformat() if r.expires_at else None,
        "max_machines":getattr(r,"max_machines",1),
        "machines":list(_get_machines(db, r.license_key)),
        "created_at":r.created_at.isoformat() if r.created_at else None,
    } for r in rows]

@app.post("/admin/licenses/{key}/revoke")
async def admin_revoke(key: str, request: Request, db=Depends(get_db)):
    _check_admin(request)
    lic = db.query(License).filter(License.license_key == key).first()
    if not lic: raise HTTPException(404,"License not found")
    lic.status = "REVOKED"; db.commit()
    return {"status":"revoked","key":key}

@app.post("/admin/licenses/{key}/activate")
async def admin_activate(key: str, request: Request, db=Depends(get_db)):
    _check_admin(request)
    lic = db.query(License).filter(License.license_key == key).first()
    if not lic: raise HTTPException(404,"License not found")
    lic.status = "ACTIVE"; db.commit()
    return {"status":"activated","key":key}

@app.post("/admin/licenses/{key}/reset-machines")
async def admin_reset_machines(key: str, request: Request, db=Depends(get_db)):
    _check_admin(request)
    _machine_registry.pop(key, None)
    try:
        db.query(LicenseActivation).filter(LicenseActivation.license_key == key).delete()
        db.commit()
    except Exception: db.rollback()
    return {"status":"machines_reset","key":key}

@app.get("/admin/stats")
async def admin_stats(request: Request, db=Depends(get_db)):
    _check_admin(request)
    return {
        "total":   db.query(License).count(),
        "active":  db.query(License).filter(License.status == "ACTIVE").count(),
        "trial":   db.query(License).filter(License.is_trial == True).count(),
        "unused":  db.query(License).filter(License.status == "UNUSED").count(),
        "pending": db.query(License).filter(License.status == "PENDING").count(),
        "revoked": db.query(License).filter(License.status == "REVOKED").count(),
        "expired": db.query(License).filter(License.status == "EXPIRED").count(),
    }


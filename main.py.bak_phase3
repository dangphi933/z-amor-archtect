# ══════════════════════════════════════════════════════════════════
# LIFESPAN
# ══════════════════════════════════════════════════════════════════
async def _rollover_loop():
    from api.config_manager import perform_daily_rollover
    from api.dashboard_service import reset_daily_cache, _mt5_cache
    while True:
        try:
            if perform_daily_rollover():
                for acc_id in list(_mt5_cache.keys()):
                    try: reset_daily_cache(acc_id)
                    except Exception as ce: logger.warning(f"[ROLLOVER] {acc_id}: {ce}")
        except Exception as e:
            logger.error(f"[ROLLOVER ERROR] {e}")
        await asyncio.sleep(60)

@asynccontextmanager
async def lifespan(app: FastAPI):
    logger.info("Z-ARMOR CLOUD — Unified Server starting...")
    Base.metadata.create_all(bind=engine)
    logger.info("Database tables ready.")
    rollover = asyncio.create_task(_rollover_loop())
    logger.info("Server ready.")
    yield
    rollover.cancel()
    logger.info("Server shutdown.")

# ══════════════════════════════════════════════════════════════════
# APP
# ══════════════════════════════════════════════════════════════════
limiter = Limiter(key_func=get_remote_address, default_limits=["200/hour"])

app = FastAPI(
    title="Z-ARMOR CLOUD",
    version="9.0.0",
    docs_url="/api/docs" if os.environ.get("DEBUG","").lower() == "true" else None,
    redoc_url=None,
    lifespan=lifespan,
)
app.state.limiter = limiter
app.add_exception_handler(RateLimitExceeded, _rate_limit_exceeded_handler)
app.add_middleware(
    CORSMiddleware, allow_origins=["*"],
    allow_credentials=True, allow_methods=["*"], allow_headers=["*"],
)
app.include_router(ea_router)


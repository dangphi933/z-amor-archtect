"""
main.py — Z-ARMOR CLOUD (Unified Single Server)
=================================================
Giai đoạn 3: Gộp dashboard (port 8001) + backend mới (port 8000) thành 1
Port duy nhất: 8000
DB duy nhất:   PostgreSQL

Routes đầy đủ:
  GET  /                      → landing page (salemain.html)
  GET  /health                → health check
  GET  /web/*                 → dashboard React SPA
  GET  /heartbeat             → EA heartbeat (GET)
  POST /heartbeat             → EA heartbeat (POST)
  GET  /api/health
  GET  /api/init-data
  POST /api/checkout          → tạo key (new backend)
  POST /api/lark-webhook      → webhook từ Lark khi có đơn paid
  POST /api/webhook/heartbeat → EA webhook legacy
  POST /api/webhook/positions
  POST /api/webhook/trade-event
  POST /api/update-unit-config
  POST /api/unlock-unit
  POST /api/panic-kill
  POST /api/test-telegram
  POST /api/send-telegram
  POST /api/bind-license
  GET  /api/verify-license/{account_id}
  POST /api/verify-license
  POST /api/log-trade
  POST /api/close-session
  POST /api/log-audit
  GET  /api/trade-history/{account_id}
  GET  /api/session-history/{account_id}
  GET  /api/sync-history/{account_id}
  GET  /api/ai-analysis/{account_id}
  POST /api/validate-key      → validate key (new backend)
  POST /admin/licenses
  GET  /admin/licenses
  POST /admin/licenses/{key}/revoke
  POST /admin/licenses/{key}/activate
  POST /admin/licenses/{key}/reset-machines
  GET  /admin/stats
"""


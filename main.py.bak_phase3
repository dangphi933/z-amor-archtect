# ══════════════════════════════════════════════════════════════════
# CHECKOUT — New backend logic (tạo key ngay, gửi email, Lark, Telegram)
# ══════════════════════════════════════════════════════════════════
@app.post("/api/checkout")
def process_checkout(req: CheckoutPayload, request: Request, db=Depends(get_db)):
    tier = req.tier.upper().strip()
    if tier not in VALID_TIERS:
        raise HTTPException(400, detail=f"Tier khong hop le: {tier}")

    is_trial = "TRIAL" in tier
    ip       = request.headers.get("X-Forwarded-For", request.client.host if request.client else "unknown")

    # Giới hạn trial
    if is_trial:
        from sqlalchemy import func as sqlfunc
        count = (
            db.query(License)
            .filter(License.buyer_email == req.buyer_email.lower(), License.is_trial == True)
            .count()
        )
        max_trial = int(os.environ.get("TRIAL_MAX_PER_EMAIL", 1))
        if count >= max_trial:
            _run_async(notify_trial_abuse(req.buyer_email, count))
            raise HTTPException(429, detail=f"Email nay da dung thu {count} lan. Vui long mua ban quyen.")

    # Tạo key
    key      = generate_license_key(tier)
    days     = int(os.environ.get("TRIAL_DURATION_DAYS", 7)) if is_trial else None
    exp      = compute_expiry(days) if days else None
    status   = "ACTIVE" if is_trial else "PENDING"

    lic = License(
        license_key    = key,
        tier           = tier,
        status         = status,
        buyer_name     = req.buyer_name,
        buyer_email    = req.buyer_email.lower(),
        is_trial       = is_trial,
        amount_usd     = req.amount,
        payment_method = req.method,
        activated_at   = datetime.utcnow() if is_trial else None,
        expires_at     = exp,
        ip_address     = ip,
    )
    db.add(lic); db.commit(); db.refresh(lic)
    logger.info(f"Key created: {key} | {tier} | {req.buyer_email}")

    # Notify admin
    _run_async(notify_new_lead(
        name=req.buyer_name, email=req.buyer_email,
        tier=tier, amount=req.amount, ip=ip, key=key,
    ))

    # Push Lark
    lark_ok = False
    try:
        import asyncio as _aio
        lark_ok = _aio.get_event_loop().run_until_complete(
            push_order_to_lark(
                key_id=lic.id, buyer_name=req.buyer_name,
                buyer_email=req.buyer_email, tier=tier,
                amount=req.amount, key=key, status=status, method=req.method,
            )
        )
    except Exception as e:
        logger.error(f"Lark push failed: {e}")
        _run_async(notify_lark_error(key, str(e)))

    # Gửi email (chỉ trial)
    email_ok = False
    if is_trial:
        try:
            import asyncio as _aio
            email_ok = _aio.get_event_loop().run_until_complete(
                send_license_email(
                    to_email=req.buyer_email, buyer_name=req.buyer_name,
                    tier=tier, license_key=key,
                    expires_at=exp.strftime("%d/%m/%Y") if exp else "7 ngay",
                )
            )
        except Exception as e:
            logger.error(f"Email failed: {e}")
        _run_async(notify_email_sent(req.buyer_email, key, email_ok))

    # Audit log
    db.add(type("AuditLog", (), {})())  # placeholder — dùng nếu có AuditLog model
    try:
        from database import AuditLog
        db.add(AuditLog(
            account_id=None, action="CHECKOUT",
            message=f"key={key} tier={tier} lark={lark_ok} email={email_ok}",
            ip_address=ip, email=req.buyer_email,
        ))
        db.commit()
    except Exception:
        pass

    msg = "Key dung thu da gui qua email!" if is_trial else "Don hang da ghi nhan. Admin se kich hoat trong 1-24h."
    return {"status":"success","message":msg,"key":key if is_trial else None}

# ══════════════════════════════════════════════════════════════════
# LARK WEBHOOK — Nhận đơn paid từ Lark
# ══════════════════════════════════════════════════════════════════
@app.post("/api/lark-webhook")
async def receive_lark_order(payload: LarkWebhookBody, db=Depends(get_db)):
    try:
        order = payload.event
        if order.payment_status.upper() != "PAID":
            return {"status":"error","message":"Don hang chua thanh toan."}
        tier    = order.purchased_tier.upper()
        new_key = generate_license_key(tier)
        lic = License(
            license_key=new_key, tier=tier, status="UNUSED",
            buyer_email=order.buyer_email, buyer_name=order.buyer_name,
        )
        db.add(lic); db.commit()
        admin_chat = os.environ.get("TELEGRAM_ADMIN_CHAT_ID","")
        if admin_chat:
            await push_to_telegram(
                chat_id=admin_chat,
                text=f"DON HANG TU LARK!\nKhach: {order.buyer_name}\nGoi: {tier}\nKey: {new_key}",
                disable_notification=False
            )
        return {"status":"success","data":{"license_key":new_key}}
    except Exception as e:
        db.rollback()
        return {"status":"error","message":str(e)}

# ══════════════════════════════════════════════════════════════════
# EA HEARTBEAT
# ══════════════════════════════════════════════════════════════════
async def _heartbeat_handler(account, magic, license, equity, balance, ts, db):
    if not license:
        return {"valid":False,"lock":False,"emergency":False,"reason":"NO_LICENSE_KEY"}

    lic = db.query(License).filter(License.license_key == license).first()
    if not lic:
        logger.warning(f"[HEARTBEAT] INVALID_KEY | account={account} key={license[:12]}...")
        return {"valid":False,"lock":False,"emergency":False,"reason":"INVALID_KEY"}

    if lic.status == "REVOKED":
        return {"valid":False,"lock":True,"emergency":False,"reason":"LICENSE_REVOKED"}

    if lic.status == "EXPIRED" or (lic.expires_at and lic.expires_at < datetime.utcnow()):
        if lic.status != "EXPIRED":
            lic.status = "EXPIRED"; db.commit()
        return {"valid":False,"lock":True,"emergency":False,"reason":"LICENSE_EXPIRED"}

    if lic.status not in ("ACTIVE","UNUSED"):
        return {"valid":False,"lock":True,"emergency":False,"reason":"LICENSE_INACTIVE"}

    max_m = getattr(lic,"max_machines",1) or 1
    known = _get_machines(db, license)
    if account and account not in known:
        if len(known) >= max_m:
            return {"valid":False,"lock":True,"emergency":False,"reason":"MACHINE_LIMIT_REACHED",
                    "detail":f"Toi da {max_m} may. Lien he admin."}
        _add_machine(db, license, account, magic)

    if account:
        lic.bound_mt5_id = lic.bound_mt5_id or account
    db.commit()
    logger.info(f"[HEARTBEAT] OK | key={license[:12]}... account={account} equity={equity:.2f}")
    return {
        "valid":True,"lock":False,"emergency":False,
        "status":lic.status,
        "expires_at": lic.expires_at.isoformat() if lic.expires_at else "lifetime",
        "reason":"OK",
    }

@app.get("/heartbeat")
async def ea_heartbeat_get(
    account:str=None, magic:str="", license:str="",
    equity:float=0, balance:float=0, ts:str="", db=Depends(get_db)
):
    return await _heartbeat_handler(account, magic, license, equity, balance, ts, db)

@app.post("/heartbeat")
async def ea_heartbeat_post(request: Request, db=Depends(get_db)):
    account=magic=license=ts=""
    equity=balance=0.0
    try:
        body    = await request.json()
        account = str(body.get("account", body.get("account_id","")) or "")
        magic   = str(body.get("magic","") or "")
        license = str(body.get("license", body.get("license_key","")) or "")
        equity  = float(body.get("equity",0) or 0)
        balance = float(body.get("balance",0) or 0)
        ts      = str(body.get("ts","") or "")
    except Exception: pass
    qp = request.query_params
    if not account: account  = qp.get("account", qp.get("account_id",""))
    if not license: license  = qp.get("license", qp.get("license_key",""))
    if not equity:  equity   = float(qp.get("equity",0) or 0)
    if not balance: balance  = float(qp.get("balance",0) or 0)
    return await _heartbeat_handler(account, magic, license, equity, balance, ts, db)

# ══════════════════════════════════════════════════════════════════
# VALIDATE KEY (new backend endpoint)
# ══════════════════════════════════════════════════════════════════
@app.post("/api/validate-key")
def validate_key(req: ValidateKeyPayload, db=Depends(get_db)):
    lic = db.query(License).filter(License.license_key == req.license_key).first()
    if not lic:
        return {"valid":False,"reason":"INVALID_KEY","tier":None}
    if lic.status == "REVOKED":
        return {"valid":False,"reason":"LICENSE_REVOKED","tier":lic.tier}
    if lic.expires_at and lic.expires_at < datetime.utcnow():
        return {"valid":False,"reason":"LICENSE_EXPIRED","tier":lic.tier,
                "expires_at":lic.expires_at.isoformat()}
    if lic.status not in ("ACTIVE","UNUSED"):
        return {"valid":False,"reason":"LICENSE_INACTIVE","tier":lic.tier}
    return {
        "valid":True,"tier":lic.tier,"status":lic.status,
        "expires_at": lic.expires_at.isoformat() if lic.expires_at else "lifetime",
        "bound_mt5_id": lic.bound_mt5_id,
    }

# ══════════════════════════════════════════════════════════════════
# MT5 WEBHOOKS (legacy)
# ══════════════════════════════════════════════════════════════════
@app.post("/api/webhook/heartbeat")
async def webhook_heartbeat(request: Request):
    raw  = await request.body()
    data = json.loads(raw.decode("utf-8").strip("\x00").strip())
    update_webhook_heartbeat(data)
    return {"status":"ok"}

@app.post("/api/webhook/positions")
async def webhook_positions(request: Request):
    raw  = await request.body()
    data = json.loads(raw.decode("utf-8").strip("\x00").strip())
    update_webhook_positions(str(data.get("account_id")), data.get("positions",[]))
    return {"status":"ok"}

@app.post("/api/webhook/trade-event")
async def webhook_trade_event(payload: TradeEventPayload):
    try:
        units  = get_all_units()
        ucfg   = units.get(payload.account_id, {})
        chat   = ucfg.get("telegram_config",{}).get("chat_id","")
        active = ucfg.get("telegram_config",{}).get("is_active", True)
        name   = ucfg.get("alias", f"Trader {payload.account_id}")
        if not chat or not active:
            return {"status":"ignored"}
        if payload.event_type.upper() == "OPEN":
            await send_trade_opened(chat_id=chat, trader_name=name,
                ticket=payload.ticket, symbol=payload.symbol,
                trade_type=payload.trade_type, volume=payload.volume, price=payload.price)
        elif payload.event_type.upper() == "CLOSE":
            await send_trade_closed(chat_id=chat, trader_name=name,
                ticket=payload.ticket, symbol=payload.symbol,
                trade_type=payload.trade_type, pnl=payload.pnl, rr_ratio=payload.rr_ratio)
        return {"status":"success"}
    except Exception as e:
        return {"status":"error","message":str(e)}

# ══════════════════════════════════════════════════════════════════
# CONFIG / CONTROL
# ══════════════════════════════════════════════════════════════════
@app.post("/api/update-unit-config")
async def update_config(request: Request):
    try:
        data       = await request.json()
        account_id = str(data.get("mt5_login") or data.get("unit_key") or "")
        if not account_id or account_id == "None":
            return {"status":"error","message":"Thieu mt5_login"}
        if "neural_profile" not in data:
            existing = get_all_units().get(account_id,{}).get("neural_profile")
            if existing: data["neural_profile"] = existing
        update_unit_from_payload(account_id, data)
        invalidate_units_cache()
        return {"status":"success"}
    except Exception as e:
        return {"status":"error","message":str(e)}

@app.post("/api/unlock-unit")
async def unlock_unit(request: Request):
    data = await request.json()
    set_lock_status(data.get("account_id"), False)
    return {"status":"unlocked"}

@app.post("/api/panic-kill")
async def panic_kill(request: Request):
    data = await request.json()
    set_lock_status(data.get("account_id"), True)
    return {"status":"locked"}

# ══════════════════════════════════════════════════════════════════
# TELEGRAM
# ══════════════════════════════════════════════════════════════════
@app.post("/api/test-telegram")
async def test_telegram(request: Request):
    data    = await request.json()
    chat_id = str(data.get("chat_id",""))
    if not chat_id: return {"status":"error","message":"Thieu chat_id"}
    await push_to_telegram(chat_id=chat_id,
        text="<b>[Z-ARMOR] Test ket noi thanh cong!</b>", disable_notification=False)
    return {"status":"ok"}

@app.post("/api/send-telegram")
async def route_send_telegram(req: SendTelegramRequest):
    return await api_send_telegram(req.account_id, req.chat_id, req.message)

# ══════════════════════════════════════════════════════════════════
# LICENSE — bind / verify
# ══════════════════════════════════════════════════════════════════
@app.post("/api/bind-license")
async def bind_license(req: BindLicensePayload, db=Depends(get_db)):
    lic = db.query(License).filter(License.license_key == req.license_key).first()
    if not lic: return {"status":"error","message":"Ma Ban quyen khong ton tai!"}
    if lic.status == "ACTIVE":
        if lic.bound_mt5_id == req.account_id:
            return {"status":"success","message":"Ban quyen nay da lien ket voi MT5 cua ban."}
        return {"status":"error","message":"Ma nay da bi su dung cho ID khac!"}
    if lic.status != "UNUSED":
        return {"status":"error","message":"Ma nay da bi khoa."}
    lic.status       = "ACTIVE"
    lic.bound_mt5_id = req.account_id
    lic.expires_at   = datetime.utcnow() + timedelta(days=30)
    lic.activated_at = datetime.utcnow()
    db.commit()
    init_payload = {
        "mt5_login": req.account_id, "alias": f"Trader {req.account_id}",
        "arm": False,
        "telegram_config": {"is_active":True},
        "risk_params": {"daily_limit_money":150,"max_dd":10.0,"dd_type":"STATIC","consistency":97},
        "neural_profile": {"trader_archetype":"SNIPER","historical_win_rate":40.0,
                           "historical_rr":1.5,"optimization_bias":"HALF_KELLY"}
    }
    update_unit_from_payload(req.account_id, init_payload)
    return {"status":"success","message":"Kich hoat thanh cong. Da cap phep 30 ngay!"}

@app.get("/api/verify-license/{account_id}")
async def verify_license_get(account_id: str, db=Depends(get_db)):
    lic = db.query(License).filter(
        License.bound_mt5_id == str(account_id), License.status == "ACTIVE"
    ).first()
    if not lic: return {"status":"error","is_valid":False,"message":"ID nay chua co Ban quyen."}
    if lic.expires_at and lic.expires_at < datetime.utcnow():
        lic.status = "EXPIRED"; db.commit()
        return {"status":"error","is_valid":False,"message":"Ban quyen DA HET HAN."}
    return {"status":"success","is_valid":True,"message":"Ban quyen Hop le",
            "tier":lic.tier,"expires_at":lic.expires_at.isoformat() if lic.expires_at else "lifetime"}

@app.post("/api/verify-license")
async def verify_license_post(request: Request, db=Depends(get_db)):
    data = await request.json()
    return await verify_license_get(str(data.get("account_id","")), db)


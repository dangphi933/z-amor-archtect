# ═══════════════════════════════════════════════════════════════════
# Z-ARMOR CLOUD — Microservices Environment Variables
# Copy sang .env và điền giá trị thực tế
# KHÔNG commit .env vào git
# ═══════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://zarmor:yourpassword@postgres:5432/zarmor

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_USE_64_CHAR_HEX
JWT_ACCESS_TTL_MINUTES=1440
JWT_REFRESH_TTL_DAYS=30

# ── EA Engine ────────────────────────────────────────────────────
# Phải khớp với cấu hình trong MT5 EA
EA_HMAC_SALT=CHANGE_ME_USE_RANDOM_STRING
ADMIN_SECRET_KEY=CHANGE_ME_ADMIN_KEY

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_ADMIN_CHAT_ID=YOUR_ADMIN_CHAT_ID
RADAR_ALERT_CHAT_ID=YOUR_RADAR_CHAT_ID

# ── Email (SMTP Gmail) ───────────────────────────────────────────
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your_app_password_16chars
SMTP_FROM_NAME=Z-ARMOR CLOUD

# ── Lark Bot ────────────────────────────────────────────────────
LARK_BOT_WEBHOOK=https://open.larksuite.com/open-apis/bot/v2/hook/...

# ── Service URLs (internal Docker network) ──────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
RADAR_SERVICE_URL=http://radar-service:8004
ML_SERVICE_URL=http://ml-service:8005

# ── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# ── Backend public URL ──────────────────────────────────────────
BACKEND_URL=https://api.yourdomain.com

# ── Feature Flags ───────────────────────────────────────────────
DEBUG=false
COOKIE_SECURE=true

# ── PostgreSQL (dùng trong docker-compose) ──────────────────────
POSTGRES_USER=zarmor
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=zarmor

# ── Market Data Service ────────────────────────────────────────────
TWELVEDATA_API_KEY=your_twelvedata_key_here
POLYGON_API_KEY=
ALPHAVANTAGE_API_KEY=

# Symbol Universe
MAX_ACTIVE_SYMBOLS=10

# ── Radar Workers ──────────────────────────────────────────────────
# Number of parallel radar worker threads
# worker-1=H1, worker-2=M15, 3+=M5/overflow
RADAR_WORKERS=2
